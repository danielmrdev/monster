{
  "name": "@monster/agents",
  "version": "0.13.3",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {},
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');fs.copyFileSync('types/index.d.ts','dist/index.d.ts')\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run --reporter verbose"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.78.0",
    "@monster/db": "workspace:*",
    "@monster/deployment": "workspace:*",
    "@monster/domains": "workspace:*",
    "@monster/seo-scorer": "workspace:*",
    "@monster/shared": "workspace:*",
    "@supabase/supabase-js": "^2.99.1",
    "bullmq": "^5.71.0",
    "cheerio": "^1.2.0",
    "cloudflare": "^5.2.0",
    "dotenv": "^17.3.1",
    "ioredis": "5.9.3",
    "marked": "^17.0.4",
    "node-ssh": "^13.2.1",
    "p-limit": "^7.3.0",
    "sharp": "^0.33.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "astro": "^6.0.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0"
  }
}
