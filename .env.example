# =============================================================================
# BuilderMonster — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct postgres connection URL — used by `supabase db push` and `supabase gen types`.
# MUST use port 5432 (direct). Do NOT use the pooler URL (port 6543) — it breaks migration tracking.
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Upstash Redis (BullMQ) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- DataForSEO ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Spaceship (Domains) ---
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# --- Amazon Associates ---
AMAZON_ACCESS_KEY_ID=
AMAZON_SECRET_ACCESS_KEY=
AMAZON_ASSOCIATE_TAG=

# --- Unsplash ---
UNSPLASH_ACCESS_KEY=

# --- Hetzner ---
HETZNER_API_TOKEN=

# --- VPS 2 (Sites) ---
VPS2_HOST=
VPS2_USER=
VPS2_SSH_KEY_PATH=

# --- App ---
NEXT_PUBLIC_APP_URL=
ADMIN_SECRET=
