{
  "name": "monster",
  "version": "0.12.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    },
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.56.0",
    "playwright": "^1.58.2"
  }
}
