---
/**
 * TSA Layout — single unified layout for all TSA (Amazon Affiliate) site pages.
 * Replaces the classic/modern/minimal triple-dispatch pattern.
 *
 * Header: centered logo variant (logo image if set, else site name link).
 * Nav: horizontal category links (desktop) + hamburger (mobile) per KN013.
 * Main: max-w-6xl centered slot area.
 * Footer: Amazon affiliate disclosure + legal links + copyright.
 */
import BaseLayout from "../BaseLayout.astro";
import type { SiteInfo, CategoryData } from "../../lib/data";

interface Props {
  title: string;
  site: SiteInfo;
  categories: CategoryData[];
  metaDescription?: string;
}

const { title, site, categories, metaDescription } = Astro.props;
const logoUrl = site.customization?.logoUrl ?? null;

const LEGAL_LINKS = [
  { href: "/privacidad/", label: "Privacidad" },
  { href: "/aviso-legal/", label: "Aviso Legal" },
  { href: "/cookies/", label: "Cookies" },
  { href: "/contacto/", label: "Contacto" },
];
---

<BaseLayout
  title={title}
  lang={site.language}
  metaDescription={metaDescription}
  customization={site.customization}
  siteId={site.id}
  supabaseUrl={site.supabase_url}
  supabaseAnonKey={site.supabase_anon_key}
>
  <!-- TSA header: centered logo + horizontal category nav + hamburger -->
  <header class="border-b border-gray-200 bg-white shadow-sm">
    <div class="mx-auto max-w-6xl px-4">
      <nav class="grid grid-cols-3 h-14 items-center">
        <!-- Left cell: hamburger (mobile only) -->
        <div class="flex items-center">
          <button
            id="nav-toggle-tsa"
            class="md:hidden flex flex-col justify-center gap-1.5 p-2 text-gray-600 hover:text-gray-900 focus:outline-none"
            aria-label="Toggle navigation"
            aria-expanded="false"
            aria-controls="mobile-menu-tsa-dropdown"
          >
            <span class="block w-5 h-0.5 bg-current"></span>
            <span class="block w-5 h-0.5 bg-current"></span>
            <span class="block w-5 h-0.5 bg-current"></span>
          </button>
        </div>
        <!-- Center cell: logo (always visible, always centered) -->
        <div class="flex justify-center min-w-0">
          {logoUrl ? (
            <a href="/" class="shrink-0 min-w-0">
              <img src={logoUrl} alt={site.name} class="h-8" />
            </a>
          ) : (
            <a href="/" class="text-xl font-bold truncate min-w-0" style="color: var(--color-primary)">
              {site.name}
            </a>
          )}
        </div>
        <!-- Right cell: desktop category links -->
        <div id="mobile-menu-tsa" class="hidden md:flex gap-4 justify-end">
          {categories.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="text-sm text-gray-600 hover:text-gray-900 transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </div>
      </nav>
    </div>
    <!-- Mobile dropdown menu: full-width stacked links, toggled by hamburger (KN013) -->
    <div id="mobile-menu-tsa-dropdown" class="hidden border-t border-gray-100 bg-white">
      <div class="mx-auto max-w-6xl px-4 py-3 flex flex-col gap-3">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}/`}
            class="text-sm text-gray-600 hover:text-gray-900 transition-colors py-1"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Main content area -->
  <main class="mx-auto max-w-6xl px-4 py-8">
    <slot />
  </main>

  <!-- TSA footer: affiliate disclosure + legal links + copyright -->
  <footer class="border-t border-gray-200 bg-gray-50 mt-12">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <!-- Amazon affiliate disclosure -->
      <p class="text-xs text-gray-500 mb-4">
        Como Asociado de Amazon, obtenemos ingresos por las compras adscritas que cumplen los requisitos aplicables.
      </p>
      <div class="flex flex-wrap gap-4">
        {LEGAL_LINKS.map((link) => (
          <a href={link.href} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-4">© {new Date().getFullYear()} {site.name}</p>
    </div>
  </footer>

  <!-- Hamburger toggle: no JS bundle, no dependencies (D163) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('nav-toggle-tsa');
      var menu = document.getElementById('mobile-menu-tsa-dropdown');
      if (btn && menu) {
        btn.addEventListener('click', function () {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });
      }
    })();
  </script>
</BaseLayout>
