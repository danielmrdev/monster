---
/**
 * TSA Layout — single unified layout for all TSA (Amazon Affiliate) site pages.
 * Replaces the classic/modern/minimal triple-dispatch pattern.
 *
 * Header: centered logo variant (logo image if set, else site name link).
 * Nav: horizontal category links (desktop) + hamburger (mobile) per KN013.
 * Main: max-w-6xl centered slot area.
 * Footer: Amazon affiliate disclosure + legal links + copyright.
 */
import BaseLayout from "../BaseLayout.astro";
import type { SiteInfo, CategoryData } from "../../lib/data";

interface Props {
  title: string;
  site: SiteInfo;
  categories: CategoryData[];
  metaDescription?: string;
  canonicalUrl?: string;
  ogData?: { title: string; description?: string; image?: string; type?: string; url: string };
  schemaData?: Record<string, unknown>[];
}

const { title, site, categories, metaDescription, canonicalUrl, ogData, schemaData } = Astro.props;
const logoUrl = site.customization?.logoUrl ?? null;

const LEGAL_LINKS = [
  { href: "/privacidad/", label: "Privacidad" },
  { href: "/aviso-legal/", label: "Aviso Legal" },
  { href: "/cookies/", label: "Cookies" },
  { href: "/contacto/", label: "Contacto" },
];
---

<BaseLayout
  title={title}
  lang={site.language}
  metaDescription={metaDescription}
  canonicalUrl={canonicalUrl}
  ogData={ogData}
  schemaData={schemaData}
  customization={site.customization}
  faviconDir={site.customization.faviconDir}
  siteId={site.id}
  supabaseUrl={site.supabase_url}
  supabaseAnonKey={site.supabase_anon_key}
>
  <!-- TSA header: logo centered row + category nav centered below -->
  <header class="border-b border-gray-200 bg-white shadow-sm">
    <div class="mx-auto max-w-4xl px-4">
      <!-- Row 1: logo centered -->
      <div class="flex items-center justify-center py-4">
        {logoUrl ? (
          <a href="/" class="shrink-0">
            <img src={logoUrl} alt={site.name} class="h-20" />
          </a>
        ) : (
          <a href="/" class="text-2xl font-bold" style="color: var(--color-primary)">
            {site.name}
          </a>
        )}
      </div>
      <!-- Row 2: category nav centered (desktop) + hamburger trigger (mobile) -->
      <div class="flex items-center justify-center border-t border-gray-100 relative">
        <!-- Mobile: hamburger left-aligned, nav hidden -->
        <button
          id="nav-toggle-tsa"
          class="md:hidden absolute left-0 flex flex-col justify-center gap-1.5 p-2 text-gray-500 hover:text-gray-900 focus:outline-none"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="mobile-menu-tsa-dropdown"
        >
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
        </button>
        <!-- Desktop: centered nav links, wraps to 2 lines if many categories -->
        <nav id="mobile-menu-tsa" class="hidden md:flex items-center justify-center flex-wrap gap-x-5 gap-y-1 py-2">
          {categories.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="nav-cat-link text-sm text-gray-600 font-medium whitespace-nowrap transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </nav>
        <!-- Mobile: placeholder to keep height when nav hidden -->
        <div class="md:hidden py-2.5"></div>
      </div>
    </div>
    <!-- Mobile dropdown: full-width stacked links (KN013 sibling pattern) -->
    <div id="mobile-menu-tsa-dropdown" class="hidden border-t border-gray-100 bg-white">
      <div class="mx-auto max-w-4xl px-4 py-3 flex flex-col gap-1">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}/`}
            class="mob-cat-link text-sm text-gray-600 transition-colors py-2 border-b border-gray-50 last:border-0"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Main content area -->
  <main class="mx-auto max-w-4xl px-4 py-8">
    <slot />
  </main>

  <!-- TSA footer: affiliate disclosure + legal links + copyright -->
  <footer class="border-t border-gray-200 bg-gray-50 mt-12">
    <div class="mx-auto max-w-4xl px-4 py-8">
      <!-- Amazon affiliate disclosure -->
      <p class="text-xs text-gray-500 mb-4">
        Como Asociado de Amazon, obtenemos ingresos por las compras adscritas que cumplen los requisitos aplicables.
      </p>
      <div class="flex flex-wrap gap-4">
        {LEGAL_LINKS.map((link) => (
          <a href={link.href} class="text-sm text-gray-500 hover:text-gray-700 transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-4">© {new Date().getFullYear()} {site.name}</p>
    </div>
  </footer>

  <!-- Hamburger toggle: no JS bundle, no dependencies (D163) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('nav-toggle-tsa');
      var menu = document.getElementById('mobile-menu-tsa-dropdown');
      if (btn && menu) {
        btn.addEventListener('click', function () {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });
      }
    })();
  </script>
  <style is:global>
    .nav-cat-link:hover { color: var(--color-primary); }
    .mob-cat-link:hover  { color: var(--color-primary); }
  </style>
</BaseLayout>
