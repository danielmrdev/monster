---
/**
 * Modern Layout — Full-width hero, sticky header, wide card grid with drop shadows.
 * Visual identity: bold colored header, hero banner section, card-heavy design with elevation.
 */
import BaseLayout from "../BaseLayout.astro";
import type { SiteInfo, CategoryData } from "../../lib/data";

interface Props {
  title: string;
  site: SiteInfo;
  categories: CategoryData[];
  heroImageUrl?: string;
  metaDescription?: string;
}

const { title, site, categories, heroImageUrl, metaDescription } = Astro.props;
const LEGAL_LINKS = [
  { href: "/privacidad/", label: "Privacidad" },
  { href: "/aviso-legal/", label: "Aviso Legal" },
  { href: "/cookies/", label: "Cookies" },
  { href: "/contacto/", label: "Contacto" },
];
---

<BaseLayout title={title} lang={site.language} metaDescription={metaDescription} customization={site.customization} siteId={site.id} supabaseUrl={site.supabase_url} supabaseAnonKey={site.supabase_anon_key}>
  <!-- Modern: sticky colored header -->
  <header
    class="sticky top-0 z-50 shadow-md"
    style="background-color: var(--color-primary);"
  >
    <div class="mx-auto max-w-7xl px-6">
      <nav class="flex h-16 items-center justify-between">
        <a href="/" class="text-xl font-extrabold text-white tracking-tight shrink-0">
          {site.name}
        </a>
        <!-- Hamburger button: visible on mobile (< md), hidden on md+ -->
        <button
          id="nav-toggle-modern"
          class="md:hidden flex flex-col justify-center gap-1.5 p-2 text-white hover:text-white/80 focus:outline-none"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="mobile-menu-modern-dropdown"
        >
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
          <span class="block w-5 h-0.5 bg-current"></span>
        </button>
        <!-- Category links: hidden on mobile, flex row on md+ -->
        <div id="mobile-menu-modern" class="hidden md:flex gap-6">
          {categories.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="text-sm font-medium text-white/90 hover:text-white transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </div>
      </nav>
    </div>
    <!-- Mobile dropdown menu: full-width stacked links, toggled by hamburger -->
    <div id="mobile-menu-modern-dropdown" class="hidden" style="background-color: var(--color-primary);">
      <div class="mx-auto max-w-7xl px-6 py-3 flex flex-col gap-3 border-t border-white/20">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}/`}
            class="text-sm font-medium text-white/90 hover:text-white transition-colors py-1"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Full-width hero band (only if heroImageUrl provided) -->
  {heroImageUrl && (
    <div
      class="w-full h-64 bg-cover bg-center relative"
      style={`background-image: url('${heroImageUrl}');`}
    >
      <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
        <h1 class="text-4xl font-extrabold text-white text-center drop-shadow-lg">{site.name}</h1>
      </div>
    </div>
  )}

  <!-- Wide main content area -->
  <main class="mx-auto max-w-7xl px-6 py-10">
    <slot />
  </main>

  <!-- Modern footer: two-tone, bold columns -->
  <footer style="background-color: var(--color-primary);" class="mt-12">
    <div class="mx-auto max-w-7xl px-6 py-10">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <p class="text-lg font-bold text-white">{site.name}</p>
          <p class="text-xs text-white/70 mt-1 max-w-md">
            Como Asociado de Amazon, obtenemos ingresos por las compras adscritas que cumplen los requisitos aplicables.
          </p>
        </div>
        <div class="flex flex-wrap gap-4">
          {LEGAL_LINKS.map((link) => (
            <a href={link.href} class="text-sm text-white/80 hover:text-white transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <p class="text-xs text-white/50 mt-6">© {new Date().getFullYear()} {site.name}</p>
    </div>
  </footer>

  <!-- Hamburger toggle: no JS bundle, no dependencies (D163) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('nav-toggle-modern');
      var menu = document.getElementById('mobile-menu-modern-dropdown');
      if (btn && menu) {
        btn.addEventListener('click', function () {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });
      }
    })();
  </script>
</BaseLayout>
