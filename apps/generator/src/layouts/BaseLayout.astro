---
import { readFileSync } from "node:fs";
import { join } from "node:path";

interface OgData {
  title: string;
  description?: string;
  /** Absolute URL to the OG image (e.g. a product or hero image). */
  image?: string;
  /** Page type — defaults to "website". */
  type?: string;
  url: string;
}

interface Props {
  title: string;
  lang?: string;
  metaDescription?: string;
  customization?: {
    primaryColor?: string;
    accentColor?: string;
    headingFont?: string;
    bodyFont?: string;
  };
  /** When set, four standard favicon <link> tags are emitted in <head>. The value is a presence signal only — hrefs use the standard filenames favicon.io generates. */
  faviconDir?: string;
  /** Analytics: site UUID written into the tracker at build time. */
  siteId?: string;
  /** Analytics: Supabase project URL written into the tracker at build time. */
  supabaseUrl?: string;
  /** Analytics: Supabase anon key (INSERT-only RLS) written into the tracker at build time. */
  supabaseAnonKey?: string;
  /** Canonical URL for this page (absolute). Emits <link rel="canonical">. */
  canonicalUrl?: string;
  /** Open Graph metadata. When provided, og: meta tags are emitted. */
  ogData?: OgData;
  /** JSON-LD structured data objects. Each is serialised as a separate <script type="application/ld+json"> tag. */
  schemaData?: Record<string, unknown>[];
}

const { title, lang = "es", metaDescription, customization, faviconDir, siteId, supabaseUrl, supabaseAnonKey, canonicalUrl, ogData, schemaData } = Astro.props;
const primary = customization?.primaryColor ?? "#4f46e5";
const accent = customization?.accentColor ?? "#7c3aed";
const headingFont = customization?.headingFont || "";
const bodyFont = customization?.bodyFont || "";

const systemFonts = new Set(["sans-serif", "serif", "monospace", "cursive", "fantasy"]);

// Build inline CSS custom properties for <html> — avoids Astro define:vars
// which sets empty-string variables that prevent CSS fallbacks from working.
const cssVarParts = [
  `--color-primary:${primary}`,
  `--color-accent:${accent}`,
];
if (bodyFont) {
  const isGeneric = systemFonts.has(bodyFont);
  cssVarParts.push(`--font-body:${isGeneric ? bodyFont : `"${bodyFont}"`}`);
}
if (headingFont) {
  const isGeneric = systemFonts.has(headingFont);
  cssVarParts.push(`--font-heading:${isGeneric ? headingFont : `"${headingFont}"`}`);
}
const htmlStyle = cssVarParts.join(";");

// Build Google Fonts URL for non-system fonts.
const fontsToLoad = [
  bodyFont && !systemFonts.has(bodyFont) ? bodyFont : null,
  headingFont && headingFont !== bodyFont && !systemFonts.has(headingFont) ? headingFont : null,
].filter((f): f is string => f !== null);
const googleFontsUrl =
  fontsToLoad.length > 0
    ? `https://fonts.googleapis.com/css2?${fontsToLoad.map((f) => `family=${f.replace(/ /g, "+")}:wght@400;500;600;700`).join("&")}&display=swap`
    : null;

// Load the pre-built tracker and substitute build-time placeholders.
// The path is relative to the monorepo root — process.cwd() during `astro build`
// is apps/generator/, so we go up two levels to reach packages/analytics/.
let trackerScript = "";
try {
  const trackerPath = join(process.cwd(), "..", "..", "packages", "analytics", "dist", "tracker.min.js");
  const raw = readFileSync(trackerPath, "utf-8");
  trackerScript = raw
    .replace("__SUPABASE_URL__", supabaseUrl ?? "")
    .replace("__SUPABASE_ANON_KEY__", supabaseAnonKey ?? "")
    .replace("__SITE_ID__", siteId ?? "");
} catch (err) {
  // Non-fatal: site still builds and works without analytics.
  console.warn("[BaseLayout] Could not load tracker.min.js:", (err as Error).message);
}
---

<html lang={lang} style={htmlStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {ogData && (
      <>
        <meta property="og:title" content={ogData.title} />
        <meta property="og:type" content={ogData.type ?? "website"} />
        <meta property="og:url" content={ogData.url} />
        {ogData.description && <meta property="og:description" content={ogData.description} />}
        {ogData.image && <meta property="og:image" content={ogData.image} />}
      </>
    )}
    {schemaData && schemaData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {faviconDir && (
      <>
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />
      </>
    )}
    {googleFontsUrl && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href={googleFontsUrl} rel="stylesheet" />
      </>
    )}
    <style>
      @import "tailwindcss";
      @plugin "@tailwindcss/typography";
    </style>
    <style is:global>
      /* Global resets — Astro scopes component styles, so these must be is:global
         to apply across all child components and page slots. */
      a {
        text-decoration: none;
        color: inherit;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
      }
    </style>
    <style is:global>
      :root {
        --font-body: sans-serif;
        --font-heading: var(--font-body);
      }
      body {
        font-family: var(--font-body, sans-serif);
      }
    </style>
  </head>
  <body>
    <slot />
    {trackerScript && <script is:inline set:html={trackerScript} />}
  </body>
</html>
