---
import { readFileSync } from "node:fs";
import { join } from "node:path";

interface Props {
  title: string;
  lang?: string;
  metaDescription?: string;
  customization?: {
    primaryColor?: string;
    accentColor?: string;
    fontFamily?: string;
  };
  /** Analytics: site UUID written into the tracker at build time. */
  siteId?: string;
  /** Analytics: Supabase project URL written into the tracker at build time. */
  supabaseUrl?: string;
  /** Analytics: Supabase anon key (INSERT-only RLS) written into the tracker at build time. */
  supabaseAnonKey?: string;
}

const { title, lang = "es", metaDescription, customization, siteId, supabaseUrl, supabaseAnonKey } = Astro.props;
const primary = customization?.primaryColor ?? "#4f46e5";
const accent = customization?.accentColor ?? "#7c3aed";
const font = customization?.fontFamily ?? "sans-serif";

// Load the pre-built tracker and substitute build-time placeholders.
// The path is relative to the monorepo root — process.cwd() during `astro build`
// is apps/generator/, so we go up two levels to reach packages/analytics/.
let trackerScript = "";
try {
  const trackerPath = join(process.cwd(), "..", "..", "packages", "analytics", "dist", "tracker.min.js");
  const raw = readFileSync(trackerPath, "utf-8");
  trackerScript = raw
    .replace("__SUPABASE_URL__", supabaseUrl ?? "")
    .replace("__SUPABASE_ANON_KEY__", supabaseAnonKey ?? "")
    .replace("__SITE_ID__", siteId ?? "");
} catch (err) {
  // Non-fatal: site still builds and works without analytics.
  console.warn("[BaseLayout] Could not load tracker.min.js:", (err as Error).message);
}
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
    <style>
      @import "tailwindcss";
      @plugin "@tailwindcss/typography";
    </style>
    <style define:vars={{ primary, accent, font }}>
      :root {
        --color-primary: var(--primary);
        --color-accent: var(--accent);
        --font-body: var(--font);
      }
      body {
        font-family: var(--font-body, sans-serif);
      }
    </style>
  </head>
  <body>
    <slot />
    {trackerScript && <script is:inline set:html={trackerScript} />}
  </body>
</html>
