---
import TsaLayout from "../layouts/tsa/Layout.astro";
import { loadSiteData } from "../lib/data";
import { buildCloakUrl } from "../lib/cloaking";
import { marked } from "marked";

function toTitleCase(str: string): string {
  return str.replace(/\w\S*/g, (w) => w.charAt(0).toUpperCase() + w.slice(1));
}

const slug = import.meta.env.SITE_SLUG ?? process.env["SITE_SLUG"] ?? "default";
const data = loadSiteData(slug);
const { site, categories, products } = data;

// Build homepage title: "{keyword} | {site.name}" — but omit the site name
// suffix when it's redundant (same as keyword, or already contained within it).
function normalize(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9]/g, '');
}
const keywordTitle = site.focus_keyword ? toTitleCase(site.focus_keyword) : '';
const siteNameNorm = normalize(site.name);
const keywordNorm  = normalize(keywordTitle);
const suffixRedundant =
  keywordNorm === siteNameNorm ||
  keywordNorm.includes(siteNameNorm) ||
  siteNameNorm.includes(keywordNorm);
const title = keywordTitle
  ? suffixRedundant ? keywordTitle : `${keywordTitle} | ${site.name}`
  : site.name;
const metaDescription = site.homepage_meta_description
  ?? (site.focus_keyword
    ? `Las mejores ${site.focus_keyword} al mejor precio. Compara, elige y ahorra en Amazon.`
    : `${site.name} — productos seleccionados al mejor precio en Amazon.`);

const siteUrl = `https://${site.domain}`;
const canonicalUrl = `${siteUrl}/`;

// OG image: first product image with a local path, or first category image
const ogImagePath =
  products.find((p) => p.images?.[0])?.images[0] ??
  categories.find((c) => c.category_image)?.category_image ??
  null;
const ogImage = ogImagePath ? `${siteUrl}${ogImagePath}` : undefined;

const ogData = {
  title,
  description: metaDescription,
  url: canonicalUrl,
  type: "website",
  ...(ogImage ? { image: ogImage } : {}),
};

const schemaData: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: siteUrl,
    description: metaDescription,
    inLanguage: site.language,
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: siteUrl,
      ...(site.customization?.logoUrl
        ? { logo: { "@type": "ImageObject", url: `${siteUrl}${site.customization.logoUrl}` } }
        : {}),
    },
  },
];
---

<TsaLayout title={title} site={site} categories={categories} metaDescription={metaDescription} canonicalUrl={canonicalUrl} ogData={ogData} schemaData={schemaData}>

  <!-- ── Page header ───────────────────────────────────────────────────── -->
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight text-center">
      {toTitleCase(site.focus_keyword ?? site.name)}
    </h1>
    {site.homepage_intro && (
      <p class="mt-4 text-base text-gray-600 max-w-2xl mx-auto text-center leading-relaxed">
        {site.homepage_intro}
      </p>
    )}
  </div>

  <!-- ── Category grid ─────────────────────────────────────────────────── -->
  <section class="mb-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="group flex flex-col rounded-xl border border-gray-200 bg-white overflow-hidden hover:border-gray-300 hover:shadow-md transition-all duration-150"
        >
          <!-- Category image — fixed height, object-contain so full image visible -->
          {cat.category_image ? (
            <img
              src={cat.category_image}
              alt={cat.name}
              class="w-full h-48 object-contain p-2"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-48 flex items-center justify-center">
              <span class="text-gray-300 text-xs">Sin imagen</span>
            </div>
          )}
          <!-- Card text: name + short description -->
          <div class="p-5 flex flex-col gap-1.5 items-center text-center">
            <h2 class="font-semibold transition-colors" style="color: var(--color-primary)">
              {cat.name}
            </h2>
            {cat.description && (
              <p class="text-sm text-gray-500 leading-relaxed">
                {cat.description}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── SEO prose text ────────────────────────────────────────────────── -->
  {site.homepage_seo_text && (
    <section class="border-t border-gray-100 pt-10">
      <div
        class="prose prose-sm max-w-none text-gray-600"
        set:html={marked(site.homepage_seo_text)}
      />
    </section>
  )}

</TsaLayout>
