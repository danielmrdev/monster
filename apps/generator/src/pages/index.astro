---
import TsaLayout from "../layouts/tsa/Layout.astro";
import { loadSiteData } from "../lib/data";
import { buildCloakUrl } from "../lib/cloaking";
import { marked } from "marked";

// Read SITE_SLUG from env — set before build() is called.
// process.cwd() = generator project root during `astro build`.
const slug = import.meta.env.SITE_SLUG ?? process.env["SITE_SLUG"] ?? "default";
const data = loadSiteData(slug);
const { site, categories, products } = data;
const featuredProducts = products.slice(0, 4);

const title = `${site.name} — Inicio`;
const metaDescription = site.focus_keyword
  ? `Las mejores ${site.focus_keyword} al mejor precio. Compara, elige y ahorra en Amazon.`
  : `${site.name} — productos seleccionados al mejor precio en Amazon.`;
const heroUrl =
  "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=80";

const CURRENCY = site.currency;
---

<TsaLayout title={title} site={site} categories={categories} metaDescription={metaDescription}>

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="relative rounded-xl overflow-hidden mb-12 h-64 sm:h-80">
    <img
      src={heroUrl}
      alt={site.name}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient overlay: dark on left, fading right -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent" />
    <div class="relative h-full flex flex-col justify-end px-8 pb-8 max-w-xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-2">
        {site.focus_keyword ?? site.name}
      </h1>
      <p class="text-sm sm:text-base text-white/80">
        {site.focus_keyword
          ? `Todo sobre ${site.focus_keyword} — guía de compra y mejores precios en Amazon`
          : "Tu tienda de confianza — los mejores productos al mejor precio"}
      </p>
    </div>
  </section>

  <!-- ── Category grid ─────────────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-lg font-semibold text-gray-800 mb-5 flex items-center gap-2">
      <span class="inline-block w-1 h-5 rounded-full" style="background-color: var(--color-primary)"></span>
      Categorías
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="group block rounded-lg border border-gray-200 bg-white overflow-hidden hover:border-gray-300 hover:shadow-md transition-all duration-150"
        >
          <!-- Vertical image or placeholder -->
          {cat.category_image ? (
            <img
              src={cat.category_image}
              alt={cat.name}
              class="w-full h-40 object-cover"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-40 bg-gray-100 flex items-center justify-center">
              <span class="text-gray-300 text-xs">Sin imagen</span>
            </div>
          )}
          <!-- Card text -->
          <div class="p-5">
            <h3 class="font-semibold text-gray-800 group-hover:text-[var(--color-primary)] transition-colors mb-2">
              {cat.name}
            </h3>
            <p class="text-sm text-gray-500 line-clamp-3 leading-relaxed">
              {cat.description ?? cat.seo_text}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Featured products ─────────────────────────────────────────────── -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-gray-800 mb-5 flex items-center gap-2">
      <span class="inline-block w-1 h-5 rounded-full" style="background-color: var(--color-accent)"></span>
      Productos Destacados
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {featuredProducts.map((p) => {
        const hasDiscount = p.original_price !== null && p.original_price > p.current_price;
        const discountPct = hasDiscount
          ? Math.round(((p.original_price! - p.current_price) / p.original_price!) * 100)
          : 0;
        return (
          <div class="flex flex-col rounded-lg border border-gray-200 bg-white overflow-hidden hover:shadow-md transition-shadow duration-150">
            <!-- Product image -->
            <a href={`/products/${p.slug}/`} class="block relative">
              {p.images[0] ? (
                <img
                  src={p.images[0]}
                  alt={p.title}
                  class="w-full h-44 object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-44 bg-gray-50 flex items-center justify-center">
                  <span class="text-gray-300 text-xs">Sin imagen</span>
                </div>
              )}
              {hasDiscount && (
                <span class="absolute top-2 right-2 text-xs font-bold text-white px-2 py-0.5 rounded-full" style="background-color: var(--color-accent)">
                  -{discountPct}%
                </span>
              )}
            </a>
            <!-- Product info -->
            <div class="flex flex-col flex-1 p-3 gap-2">
              <a href={`/products/${p.slug}/`} class="text-sm font-medium text-gray-800 line-clamp-2 hover:text-[var(--color-primary)] transition-colors leading-snug">
                {p.title}
              </a>
              <!-- Price -->
              <div class="flex items-baseline gap-2">
                <span class="text-base font-bold" style="color: var(--color-primary)">
                  {CURRENCY} {p.current_price.toFixed(2)}
                </span>
                {hasDiscount && (
                  <span class="text-xs text-gray-400 line-through">
                    {CURRENCY} {p.original_price!.toFixed(2)}
                  </span>
                )}
              </div>
              <!-- CTA -->
              <a
                href={buildCloakUrl(p.slug)}
                rel="nofollow sponsored"
                data-affiliate={p.asin}
                class="mt-auto block text-center text-xs font-semibold text-white py-2 rounded-md transition-opacity hover:opacity-90"
                style="background-color: var(--color-accent)"
              >
                Ver en Amazon
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>
  <!-- ── Homepage SEO Text ─────────────────────────────────────────────── -->
  {site.homepage_seo_text && (
    <section class="mt-12 border-t border-gray-100 pt-10">
      <div class="prose prose-sm max-w-none text-gray-600"
        set:html={marked(site.homepage_seo_text)}
      />
    </section>
  )}

</TsaLayout>
