---
import TsaLayout from "../../layouts/tsa/Layout.astro";
import { loadSiteData } from "../../lib/data";
import { buildCloakUrl } from "../../lib/cloaking";
import { marked } from "marked";

function toTitleCase(str: string): string {
  return str.replace(/\w\S*/g, (w) => w.charAt(0).toUpperCase() + w.slice(1));
}
import type { SiteData, SiteInfo, CategoryData, ProductData } from "../../lib/data";

export async function getStaticPaths() {
  const slug = import.meta.env.SITE_SLUG ?? process.env.SITE_SLUG ?? "default";
  const data: SiteData = loadSiteData(slug);

  return data.categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      site: data.site,
      categories: data.categories,
      category,
      products: data.products.filter((p) => p.category_slug === category.slug),
    },
  }));
}

interface Props {
  site: SiteInfo;
  categories: CategoryData[];
  category: CategoryData;
  products: ProductData[];
}

const { site, categories, category, products } = Astro.props;
const title = `${category.name} — ${site.name}`;
const CURRENCY = site.currency;
const metaDescription = category.meta_description ?? undefined;

const siteUrl = `https://${site.domain}`;
const canonicalUrl = `${siteUrl}/categories/${category.slug}/`;

const ogImage = category.category_image ? `${siteUrl}${category.category_image}` : undefined;
const ogData = {
  title,
  description: metaDescription,
  url: canonicalUrl,
  type: "website",
  ...(ogImage ? { image: ogImage } : {}),
};

const schemaData: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: category.name,
    url: canonicalUrl,
    description: metaDescription,
    inLanguage: site.language,
    isPartOf: { "@type": "WebSite", name: site.name, url: siteUrl },
  },
];

// Related categories: up to 3 others (excluding current)
const relatedCategories = categories.filter((c) => c.slug !== category.slug).slice(0, 3);
---

<TsaLayout title={title} site={site} categories={categories} metaDescription={metaDescription} canonicalUrl={canonicalUrl} ogData={ogData} schemaData={schemaData}>

  <!-- ── Category header ───────────────────────────────────────────────── -->
  <div class="mb-8">
    <nav class="text-xs text-gray-400 mb-3 flex items-center gap-1">
      <a href="/" class="hover:text-gray-600 transition-colors">Inicio</a>
      <span>/</span>
      <span class="font-medium" style="color: var(--color-primary)">{category.name}</span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-bold mb-2 text-center" style="color: var(--color-primary)">
      {toTitleCase(category.name)}
    </h1>
    {category.category_image && (
      <img
        src={category.category_image}
        alt={category.focus_keyword ?? category.name}
        class="mx-auto mb-3 h-40 w-auto object-contain"
        loading="eager"
      />
    )}
    {category.description && (
      <p class="text-gray-500 max-w-3xl leading-relaxed text-sm sm:text-base">
        {category.description}
      </p>
    )}
  </div>

  <!-- ── Product grid ──────────────────────────────────────────────────── -->
  {products.length > 0 ? (
    <section class="mb-14">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {products.map((p) => {
          const hasDiscount = p.original_price !== null && p.original_price > p.current_price;
          const discountPct = hasDiscount
            ? Math.round(((p.original_price! - p.current_price) / p.original_price!) * 100)
            : 0;
          return (
            <div class="flex flex-col rounded-xl border border-gray-200 bg-white overflow-hidden hover:shadow-md transition-shadow duration-150">
              <!-- Fixed height image — object-contain so full product visible -->
              <a href={`/products/${p.slug}/`} class="block relative">
                {p.images[0] ? (
                  <img
                    src={p.images[0]}
                    alt={p.title}
                    class="w-full h-48 object-contain bg-white p-3"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-48 bg-gray-50 flex items-center justify-center">
                    <span class="text-gray-300 text-xs">Sin imagen</span>
                  </div>
                )}
                {hasDiscount && (
                  <span
                    class="absolute top-2 right-2 text-xs font-bold text-white px-2 py-0.5 rounded-full"
                    style="background-color: var(--color-accent)"
                  >
                    -{discountPct}%
                  </span>
                )}
              </a>
              <!-- Product info -->
              <div class="flex flex-col flex-1 p-4 gap-2">
                <a
                  href={`/products/${p.slug}/`}
                  class="text-sm font-semibold text-gray-800 line-clamp-2 hover:text-[var(--color-primary)] transition-colors leading-snug"
                >
                  {p.title}
                </a>
                <!-- Price row -->
                <div class="flex items-baseline gap-2 mt-auto">
                  <span class="text-base font-bold" style="color: var(--color-primary)">
                    {CURRENCY} {p.current_price.toFixed(2)}
                  </span>
                  {hasDiscount && (
                    <span class="text-xs text-gray-400 line-through">
                      {CURRENCY} {p.original_price!.toFixed(2)}
                    </span>
                  )}
                </div>
                <!-- CTA row -->
                <div class="flex gap-2 mt-1">
                  <a
                    href={`/products/${p.slug}/`}
                    class="flex-1 text-center text-xs font-medium border border-gray-300 text-gray-700 py-1.5 rounded-md hover:border-gray-400 hover:bg-gray-50 transition-colors"
                  >
                    + info
                  </a>
                  <a
                    href={buildCloakUrl(p.slug)}
                    rel="nofollow sponsored"
                    data-affiliate={p.asin}
                    class="flex-1 text-center text-xs font-semibold text-white py-1.5 rounded-md transition-opacity hover:opacity-90"
                    style="background-color: var(--color-accent)"
                  >
                    Comprar
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  ) : (
    <p class="text-gray-500 text-sm mb-14">No hay productos en esta categoría aún.</p>
  )}

  <!-- ── SEO prose text — at bottom ────────────────────────────────────── -->
  {category.seo_text && (
    <section class="mb-14 border-t border-gray-100 pt-8">
      <div
        class="prose prose-sm max-w-none text-gray-600"
        set:html={marked(category.seo_text)}
      />
    </section>
  )}

  <!-- ── Related categories — at bottom ───────────────────────────────── -->
  {relatedCategories.length > 0 && (
    <section class="border-t border-gray-100 pt-8">
      <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wider mb-6 text-center">
        Otras categorías
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {relatedCategories.map((cat) => (
          <a
            href={`/categories/${cat.slug}/`}
            class="group flex flex-col rounded-xl border border-gray-200 bg-white overflow-hidden hover:border-gray-300 hover:shadow-md transition-all duration-150"
          >
            {cat.category_image ? (
              <img
                src={cat.category_image}
                alt={cat.name}
                class="w-full h-48 object-contain p-2"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-48 flex items-center justify-center">
                <span class="text-gray-300 text-xs">Sin imagen</span>
              </div>
            )}
            <div class="p-5 flex flex-col gap-1.5 items-center text-center">
              <h3 class="font-semibold transition-colors" style="color: var(--color-primary)">
                {cat.name}
              </h3>
              {cat.description && (
                <p class="text-sm text-gray-500 leading-relaxed">
                  {cat.description}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

</TsaLayout>
