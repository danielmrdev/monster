---
import TsaLayout from "../../layouts/tsa/Layout.astro";
import { loadSiteData } from "../../lib/data";
import { buildCloakUrl } from "../../lib/cloaking";
import { marked } from "marked";
import type { SiteData, SiteInfo, CategoryData, ProductData, ProsCons } from "../../lib/data";

export async function getStaticPaths() {
  const slug = import.meta.env.SITE_SLUG ?? process.env.SITE_SLUG ?? "default";
  const data: SiteData = loadSiteData(slug);

  return data.products.map((product) => ({
    params: { slug: product.slug },
    props: {
      site: data.site,
      categories: data.categories,
      product,
    },
  }));
}

const { site, categories, product } = Astro.props as {
  site: SiteInfo;
  categories: CategoryData[];
  product: ProductData;
};
const title = `${product.optimized_title ?? product.title} — ${site.name}`;
const CURRENCY = site.currency;
const cloakUrl = buildCloakUrl(product.slug);
const prosCons = product.pros_cons as ProsCons | null;
const metaDescription = product.meta_description ?? undefined;

const siteUrl = `https://${site.domain}`;
const canonicalUrl = `${siteUrl}/products/${product.slug}/`;

const ogImage = product.images?.[0] ? `${siteUrl}${product.images[0]}` : undefined;
const ogData = {
  title,
  description: metaDescription,
  url: canonicalUrl,
  type: "product",
  ...(ogImage ? { image: ogImage } : {}),
};

const schemaData: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.title,
    url: canonicalUrl,
    ...(ogImage ? { image: ogImage } : {}),
    ...(metaDescription ? { description: metaDescription } : {}),
    ...(product.rating > 0 ? {
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: product.rating,
        reviewCount: 1,
        bestRating: 5,
        worstRating: 1,
      },
    } : {}),
    offers: {
      "@type": "Offer",
      price: product.current_price,
      priceCurrency: site.currency,
      availability: "https://schema.org/InStock",
      url: canonicalUrl,
    },
  },
];

// Discount logic
const hasDiscount =
  product.original_price !== null && product.original_price > product.current_price;
const discountPct = hasDiscount
  ? Math.round(
      ((product.original_price! - product.current_price) / product.original_price!) * 100
    )
  : 0;

// Parent category for breadcrumb
const parentCategory = categories.find((c) => c.slug === product.category_slug) ?? null;
---

<TsaLayout title={title} site={site} categories={categories} metaDescription={metaDescription} canonicalUrl={canonicalUrl} ogData={ogData} schemaData={schemaData}>

  <!-- ── Breadcrumb ────────────────────────────────────────────────────── -->
  <nav class="text-xs text-gray-400 mb-6 flex items-center gap-1">
    <a href="/" class="hover:text-gray-600 transition-colors">Inicio</a>
    {parentCategory && (
      <>
        <span>/</span>
        <a href={`/categories/${parentCategory.slug}/`} class="hover:text-[var(--color-primary)] transition-colors">
          {parentCategory.name}
        </a>
      </>
    )}
    <span>/</span>
    <span class="font-medium truncate max-w-[200px]" style="color: var(--color-primary)">{product.title}</span>
  </nav>

  <div class="lg:grid lg:grid-cols-[1fr_400px] lg:gap-10">

    <!-- ── Left: image gallery ─────────────────────────────────────────── -->
    <div class="mb-8 lg:mb-0">
      {product.images.length > 0 ? (
        <div class="space-y-3">
          <!-- Main image -->
          <div class="rounded-xl overflow-hidden border border-gray-200 bg-white">
            <img
              src={product.images[0]}
              alt={product.title}
              class="w-full max-h-96 object-contain p-4"
              loading="eager"
              id="product-main-img"
            />
          </div>
          <!-- Thumbnail row (if more than one image) -->
          {product.images.length > 1 && (
            <div class="flex gap-2 overflow-x-auto pb-1">
              {product.images.map((img, i) => (
                <button
                  type="button"
                  class="shrink-0 rounded-lg border-2 overflow-hidden transition-colors hover:border-[var(--color-primary)]"
                  style={i === 0 ? "border-color: var(--color-primary)" : "border-color: transparent"}
                  data-img={img}
                  data-thumb-btn
                >
                  <img src={img} alt={`${product.title} — imagen ${i + 1}`} class="w-16 h-16 object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>
      ) : (
        <div class="rounded-xl border border-gray-200 bg-gray-50 flex items-center justify-center h-40 sm:h-56 lg:h-full">
          <span class="text-gray-300 text-sm">Sin imagen</span>
        </div>
      )}
    </div>

    <!-- ── Right: product info panel ──────────────────────────────────── -->
    <div class="flex flex-col gap-4">

      <!-- Title + badges -->
      <div>
        <h1 class="text-xl sm:text-2xl font-bold text-gray-800 leading-snug mb-3">
          {product.optimized_title ?? product.title}
        </h1>
        <div class="flex flex-wrap items-center gap-2">
          {product.is_prime && (
            <span class="inline-flex items-center gap-1 text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200 px-2 py-0.5 rounded">
              Prime
            </span>
          )}
          {product.rating > 0 && (
            <span class="inline-flex items-center gap-1 text-xs text-gray-500 border border-gray-200 px-2 py-0.5 rounded bg-white">
              ★ {product.rating.toFixed(1)}
            </span>
          )}
          {hasDiscount && (
            <span class="inline-flex items-center text-xs font-bold text-white px-2 py-0.5 rounded" style="background-color: var(--color-accent)">
              -{discountPct}% dto.
            </span>
          )}
        </div>
      </div>

      <!-- Price block -->
      <div class="border-t border-b border-gray-100 py-4">
        <div class="flex items-baseline gap-3">
          <span class="text-3xl font-bold" style="color: var(--color-primary)">
            {CURRENCY} {product.current_price.toFixed(2)}
          </span>
          {hasDiscount && (
            <span class="text-base text-gray-400 line-through">
              {CURRENCY} {product.original_price!.toFixed(2)}
            </span>
          )}
        </div>
        {hasDiscount && (
          <p class="text-xs text-gray-500 mt-1">
            Ahorra {CURRENCY} {(product.original_price! - product.current_price).toFixed(2)} ({discountPct}%)
          </p>
        )}
      </div>

      <!-- Comprar button -->
      <a
        href={cloakUrl}
        rel="nofollow sponsored"
        data-affiliate={product.asin}
        class="block w-full text-center text-sm font-semibold text-white py-3 rounded-lg transition-opacity hover:opacity-90"
        style="background-color: var(--color-accent)"
      >
        Comprar en Amazon →
      </a>

      <!-- Disclosure -->
      <p class="text-xs text-gray-400 leading-relaxed">
        Como Asociado de Amazon obtenemos ingresos por las compras adscritas que cumplen los requisitos aplicables.
      </p>

    </div>
  </div>

  <!-- ── AI description ─────────────────────────────────────────────────── -->
  {product.detailed_description && (
    <section class="mt-10 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-800 mb-3">Descripción</h2>
      <div
        class="prose prose-sm max-w-none text-gray-600"
        set:html={marked(product.detailed_description)}
      />
    </section>
  )}

  <!-- ── User opinions summary ──────────────────────────────────────────── -->
  {product.user_opinions_summary && (
    <section class="mt-8 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-800 mb-3">Opiniones de compradores</h2>
      <div
        class="prose prose-sm max-w-none text-gray-600"
        set:html={marked(product.user_opinions_summary)}
      />
    </section>
  )}

  <!-- ── Pros/cons ──────────────────────────────────────────────────────── -->
  {prosCons && (
    <section class="mt-8 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Pros y contras</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Pros -->
        <div class="rounded-xl border border-gray-200 bg-white overflow-hidden border-l-4 border-l-green-500">
          <div class="flex items-center gap-2 px-4 py-3 bg-green-50 border-b border-gray-100">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="8" fill="#22c55e" fill-opacity="0.2"/>
              <path d="M4.5 8l2.5 2.5 4.5-5" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-sm font-semibold text-green-800">Ventajas</span>
          </div>
          <ul class="divide-y divide-gray-50">
            {prosCons.pros.map((pro) => (
              <li class="flex items-start gap-3 px-4 py-2.5">
                <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4.5 8l2.5 2.5 4.5-5" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-sm text-gray-700 leading-snug">{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <!-- Cons -->
        <div class="rounded-xl border border-gray-200 bg-white overflow-hidden border-l-4 border-l-amber-400">
          <div class="flex items-center gap-2 px-4 py-3 bg-amber-50 border-b border-gray-100">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="8" fill="#f59e0b" fill-opacity="0.2"/>
              <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="#d97706" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-sm font-semibold text-amber-800">Inconvenientes</span>
          </div>
          <ul class="divide-y divide-gray-50">
            {prosCons.cons.map((con) => (
              <li class="flex items-start gap-3 px-4 py-2.5">
                <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="#d97706" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span class="text-sm text-gray-700 leading-snug">{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <!-- ── Back to category ───────────────────────────────────────────────── -->
  {parentCategory && (
    <div class="mt-10 pt-6 border-t border-gray-100">
      <a
        href={`/categories/${parentCategory.slug}/`}
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 transition-colors"
      >
        ← Ver todos los productos de {parentCategory.name}
      </a>
    </div>
  )}

</TsaLayout>

<!-- Thumbnail gallery switcher: inline script, no bundle (D163) -->
{product.images.length > 1 && (
  <script is:inline>
    (function () {
      var mainImg = document.getElementById('product-main-img');
      var thumbBtns = document.querySelectorAll('[data-thumb-btn]');
      if (!mainImg || !thumbBtns.length) return;
      thumbBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var src = btn.getAttribute('data-img');
          if (src) mainImg.setAttribute('src', src);
          thumbBtns.forEach(function (b) { b.style.borderColor = 'transparent'; });
          btn.style.borderColor = 'var(--color-primary)';
        });
      });
    })();
  </script>
)}
