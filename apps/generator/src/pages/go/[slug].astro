---
/**
 * /go/[slug]/ — Static affiliate link redirect pages.
 *
 * One page generated per product at build time.
 * Uses HTML meta-refresh for the actual redirect (static site — no server-side 302).
 *
 * SEO: noindex + nofollow on these pages so only the product pages rank.
 * The affiliate link itself is on the product/category pages as /go/{slug}/
 * with rel="nofollow sponsored".
 */
import { loadSiteData } from "../../lib/data";
import { buildCloakMap } from "../../lib/cloaking";
import type { SiteData } from "../../lib/data";

export function getStaticPaths() {
  const slug = import.meta.env.SITE_SLUG ?? process.env.SITE_SLUG ?? "default";
  const data: SiteData = loadSiteData(slug);
  const { site, products } = data;

  const cloakMap = buildCloakMap(products, site.market, site.affiliate_tag);

  return products.map((product) => ({
    params: { slug: product.slug },
    props: {
      affiliateUrl: cloakMap[product.slug] ?? "",
      productTitle: product.title,
    },
  }));
}

interface Props {
  affiliateUrl: string;
  productTitle: string;
}

const { affiliateUrl, productTitle } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content={`0; url=${affiliateUrl}`} />
    <link rel="canonical" href={affiliateUrl} />
    <title>Redirigiendo…</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: ui-sans-serif, system-ui, sans-serif;
        background: #f9fafb;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        color: #6b7280;
      }
      .wrap { text-align: center; padding: 2rem; }
      .spinner {
        width: 32px; height: 32px;
        border: 3px solid #e5e7eb;
        border-top-color: #6b7280;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin: 0 auto 1rem;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      p { font-size: 0.875rem; }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="spinner"></div>
      <p><a href={affiliateUrl} rel="nofollow sponsored">Abriendo en Amazon…</a></p>
    </div>
    <script is:inline define:vars={{ affiliateUrl }}>
      setTimeout(function() { window.location.href = affiliateUrl; }, 100);
    </script>
  </body>
</html>
